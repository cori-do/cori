{
  "name": "@cori-do/workflow-capture-benchmark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "External-state benchmark for capturing Google Workspace tasks as Cori workflows.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
