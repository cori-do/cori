{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Cori launcher-first multi-window — IPC + window spawning + scoped sidecar spawn.",
  "windows": ["launcher", "launch-*", "run-*", "manage"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-set-focus",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-set-title",
    "core:webview:allow-create-webview-window",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "temporal",
          "sidecar": true,
          "args": [
            "server",
            "start-dev",
            "--port",
            { "validator": "^\\d+$" },
            "--ui-port",
            { "validator": "^\\d+$" },
            "--headless",
            "--db-filename",
            { "validator": ".*" },
            "--log-level",
            { "validator": "^(error|warn|info|debug)$" }
          ]
        }
      ]
    },
    "shell:allow-kill",
    "opener:default"
  ]
}
