<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Notarization forces the hardened runtime, which blocks writable+
         executable memory. The bundled Deno sidecar embeds V8 and needs
         JIT pages; without these entitlements the signed sidecar crashes
         at startup with SIGKILL (Code Signature Invalid). -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
</dict>
</plist>
