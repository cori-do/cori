{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cori",
  "version": "0.1.4-dev",
  "identifier": "do.cori.console",
  "build": {
    "beforeDevCommand": "pnpm vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm vite:build",
    "frontendDist": "../build/client"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cori",
        "width": 1100,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; img-src 'self' tauri: data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/temporal"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
