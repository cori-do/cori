{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cori",
  "version": "0.3.7",
  "identifier": "do.cori.console",
  "build": {
    "beforeDevCommand": "pnpm vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm vite:build",
    "frontendDist": "../build/client"
  },
  "app": {
    "windows": [
      {
        "label": "launcher",
        "title": "Cori",
        "url": "/launcher",
        "width": 520,
        "height": 620,
        "minWidth": 420,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; img-src 'self' tauri: data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/temporal", "binaries/deno", "binaries/cori-cli"],
    "macOS": {
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["cori"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNDODRDOTI1NDYwMERBMEIKUldRTDJnQkdKY21FUElkZUhybXVyT0RiM3lEZFZ6ZldsL0RtK1FWOHEvK25uSFZTL0xzdDhURlAK",
      "endpoints": ["https://cori.do/updates/latest.json"]
    }
  }
}
